<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F">

    <!-- ===== HEADER ثابت ===== -->
    <RelativeLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:paddingHorizontal="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="16dp"
        android:background="#0A0A0F">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentStart="true"
            android:layout_marginStart="30dp"
            android:src="@drawable/ic_menu" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="DIGITAL SANCTUARY"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.2" />

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentEnd="true"
            android:layout_marginEnd="21dp"
            android:src="@drawable/ic_notification"
            app:tint="#00E5FF" />
    </RelativeLayout>

    <!-- ===== المحتوى ===== -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/topBar"
        android:layout_above="@+id/bottomNavBar"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="8dp"
            android:paddingBottom="24dp">

            <!-- Dashboard Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dashboard"
                android:textColor="#FFFFFF"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="24dp"
                android:text="Deep focus analytics for your current session."
                android:textColor="#666680"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.3" />

            <!-- ====== بطاقة SELF REGULATION SCORE مع التوهج ====== -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp">

                <!-- طبقة التوهج الخارجي -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_glow_card"
                    android:alpha="0.6" />

                <!-- المحتوى -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_glow_card"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <!-- العنوان + أيقونة البرق -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:text="SELF REGULATION SCORE"
                            android:textColor="#AAAACC"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05" />

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_sparkle"
                            app:tint="#00E5FF" />
                    </RelativeLayout>

                    <!-- الرقم 65 الكبير -->
                    <TextView
                        android:id="@+id/srlScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:textColor="#00E5FF"
                        android:textSize="72sp"
                        android:textStyle="bold" />
                    <!-- Progress Bar -->
                    <ProgressBar
                        style="?android:attr/progressBarStyleHorizontal"
                        android:id="@+id/srlProgress"
                        android:layout_width="match_parent"
                        android:layout_height="5dp"
                        android:progressDrawable="@drawable/bg_goal_progress" />
                </LinearLayout>
            </FrameLayout>

            <!-- ====== Weekly Consistency ====== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Weekly Consistency"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <!-- دوائر الأيام 1-7 -->
            <LinearLayout
                android:id="@+id/weeklyContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="28dp">

                <TextView     android:id="@+id/day1" android:layout_width="38dp" android:layout_height="38dp"
                    android:text="1" android:textColor="#666680" android:gravity="center"
                    android:background="@drawable/circle_unselected"
                    android:layout_marginEnd="6dp" android:textSize="13sp"/>

                <TextView     android:id="@+id/day2" android:layout_width="38dp" android:layout_height="38dp"
                    android:text="2" android:textColor="#666680" android:gravity="center"
                    android:background="@drawable/circle_unselected"
                    android:layout_marginEnd="6dp" android:textSize="13sp"/>

                <TextView     android:id="@+id/day3" android:layout_width="38dp" android:layout_height="38dp"
                    android:text="3" android:textColor="#666680" android:gravity="center"
                    android:background="@drawable/circle_unselected"
                    android:layout_marginEnd="6dp" android:textSize="13sp"/>

                <TextView     android:id="@+id/day4" android:layout_width="38dp" android:layout_height="38dp"
                    android:text="4" android:textColor="#666680" android:gravity="center"
                    android:background="@drawable/circle_unselected"
                    android:layout_marginEnd="6dp" android:textSize="13sp"/>

                <TextView     android:id="@+id/day5" android:layout_width="38dp" android:layout_height="38dp"
                    android:text="5" android:textColor="#666680" android:gravity="center"
                    android:background="@drawable/circle_unselected"
                    android:layout_marginEnd="6dp" android:textSize="13sp"/>

                <TextView     android:id="@+id/day6" android:layout_width="38dp" android:layout_height="38dp"
                    android:text="6" android:textColor="#666680" android:gravity="center"
                    android:background="@drawable/circle_unselected"
                    android:layout_marginEnd="6dp" android:textSize="13sp"/>

                <!-- اليوم 7 مفعّل بالسيان -->
                <TextView     android:id="@+id/day7" android:layout_width="38dp" android:layout_height="38dp"
                    android:text="7" android:textColor="#666680" android:gravity="center"
                    android:textStyle="bold" android:textSize="13sp"
                    android:background="@drawable/circle_unselected"/>
            </LinearLayout>

            <!-- ====== OBSERVATION ====== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_rounded"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="top"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:background="@drawable/bg_card_dark_rounded"
                    android:padding="7dp"
                    android:src="@drawable/ic_sparkle"
                    app:tint="#00E5FF" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="OBSERVATION"
                        android:textColor="#00E5FF"
                        android:textSize="11sp"
                        android:letterSpacing="0.1"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/observationText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="#888899"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.4" />
                </LinearLayout>
            </LinearLayout>

            <!-- ====== Focus Efficiency Trend ====== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_rounded"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <ImageView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:background="@drawable/bg_card_dark_rounded"
                        android:padding="7dp"
                        android:src="@drawable/ic_chart"
                        app:tint="#00E5FF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="Focus Efficiency Trend"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- COMPLETION RATE + AVERAGE FOCUS -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="COMPLETION RATE"
                            android:textColor="#666680"
                            android:textSize="10sp"
                            android:letterSpacing="0.05" />

                        <TextView
                         android:id="@+id/completionRate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:textColor="#FFFFFF"
                            android:textSize="30sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AVERAGE FOCUS"
                            android:textColor="#666680"
                            android:textSize="10sp"
                            android:letterSpacing="0.05" />

                        <TextView
                         android:id="@+id/focusRate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:textColor="#FFFFFF"
                            android:textSize="30sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- ====== Emotional Trend ====== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_rounded"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Emotional Trend"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="Cognitive wellness monitoring."
                        android:textColor="#666680"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.3" />

                    <!-- EQUANIMITY badge -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/tab_active_bg"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="5dp">

                        <View
                            android:layout_width="7dp"
                            android:layout_height="7dp"
                            android:background="@drawable/circle_selected" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:text="EQUANIMITY"
                            android:textColor="#00E5FF"
                            android:textSize="10sp" />
                    </LinearLayout>
                </RelativeLayout>

                <!-- رسم الموجة -->
                <com.example.projectpfe.WaveView
                    android:id="@+id/waveView"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:layout_marginBottom="10dp" />

                <!-- DAY1 - DAY3 - DAY7 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="DAY1"
                        android:textColor="#444455" android:textSize="10sp"/>

                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="DAY4"
                        android:textColor="#444455" android:textSize="10sp"
                        android:gravity="center"/>

                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="DAY7"
                        android:textColor="#444455" android:textSize="10sp"
                        android:gravity="end"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ===== Bottom Navigation Bar ===== -->
    <LinearLayout
        android:id="@+id/bottomNavBar"
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:layout_alignParentBottom="true"
        android:background="@drawable/bg_nav_bar"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="8dp">

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@drawable/ic_home" app:tint="#666680"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@drawable/ic_chart" app:tint="#666680"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@drawable/ic_person" app:tint="#666680"/>
        </LinearLayout>

        <!-- Dashboard مفعّل - الأيقونة 4 -->
        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@drawable/ic_modules" app:tint="#00E5FF"/>
            <View android:layout_width="4dp" android:layout_height="4dp"
                android:layout_marginTop="4dp" android:background="#00E5FF"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@drawable/ic_book" app:tint="#666680"/>
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>