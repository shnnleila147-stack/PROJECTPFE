<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F">

    <!-- HEADER -->
    <RelativeLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:paddingHorizontal="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="12dp"
        android:background="#0A0A0F">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentStart="true"
            android:layout_marginStart="24dp"
            android:src="@drawable/ic_menu" />

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentEnd="true"
            android:layout_marginEnd="24dp"
            android:src="@drawable/ic_notification"
            app:tint="#00E5FF" />
    </RelativeLayout>

    <!-- TABS -->
    <LinearLayout
        android:id="@+id/tabsLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/topBar"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingBottom="8dp"
        android:background="#0A0A0F">

        <TextView
            android:id="@+id/tabToDo"
            android:layout_width="94dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:background="@drawable/tab_inactive_bg"
            android:gravity="center"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp"
            android:text="TODO"
            android:textColor="#666680"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tabDoing"
            android:layout_width="99dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:background="@drawable/tab_inactive_bg"
            android:gravity="center"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp"
            android:text="DOING"
            android:textColor="#666680"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tabDone"
            android:layout_width="78dp"
            android:layout_height="wrap_content"
            android:background="@drawable/tab_active_bg"
            android:gravity="center"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp"
            android:text="DONE"
            android:textColor="#00E5FF"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- CONTENT -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/tabsLayout"
        android:layout_above="@+id/bottomNavBar"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="24dp">

            <!-- DAILY SESSION FINALIZED -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.1"
                android:text="DAILY SESSION FINALIZED"
                android:textColor="#666680"
                android:textSize="11sp" />

            <!-- Reflection Portal -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Reflection Portal"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp"
                android:lineSpacingMultiplier="1.4"
                android:text="Your output today has been recorded. Take a moment to calibrate your trajectory before closing the cycle."
                android:textColor="#666680"
                android:textSize="13sp" />

            <!-- ====== Achievement Reflection ====== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_card_rounded"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- عنوان القسم -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_target"
                        app:tint="#00E5FF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Achievement Reflection"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- HOW MUCH DID YOU ACHIVE YOU OBJ? -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="HOW MUCH DID YOU ACHIVE YOU OBJ?"
                        android:textColor="#888899"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/txtAchieveValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:textColor="#00E5FF"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </RelativeLayout>

                <SeekBar
                    android:id="@+id/seekAchieve"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="16dp"
                    android:progressBackgroundTint="#1A1A2E"
                    android:progressTint="#00E5FF"
                    android:thumbTint="#00E5FF" />

                <!-- LEVEL OF UNDERSTANDING -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="LEVEL OF UNDERSTANDING"
                        android:textColor="#888899"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/txtUnderstandingValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:textColor="#00E5FF"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </RelativeLayout>

                <!-- سؤال نصي -->
                <SeekBar
                    android:id="@+id/seekUnderstanding"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="16dp"
                    android:progressBackgroundTint="#1A1A2E"
                    android:progressTint="#00E5FF"
                    android:thumbTint="#00E5FF" />

                <EditText
                    android:id="@+id/editLearning"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/input_field_bg"
                    android:hint="What is the most important thing you learning ?"
                    android:paddingHorizontal="14dp"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#333344"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- ====== Strategy Evolution ====== -->

            <!-- ====== Effort and Focus ====== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_card_rounded"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_chart"
                        app:tint="#00E5FF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Strategy Evolution"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- WAS THE STUDY PLAN EFFECTIVE? -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="WAS THE STUDY PLAN EFFECTIVE?"
                        android:textColor="#888899"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/txtPlanValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:textColor="#00E5FF"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </RelativeLayout>

                <SeekBar
                    android:id="@+id/seekPlan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="16dp"
                    android:progressBackgroundTint="#1A1A2E"
                    android:progressTint="#00E5FF"
                    android:thumbTint="#00E5FF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="Which part helped you most ?"
                    android:textColor="#AAAACC"
                    android:textSize="13sp" />

                <!-- Tags: Understanding / Practice / Summary -->

                <!-- Self-test tag -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tagUnderstanding"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/tab_inactive_bg"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="8dp"
                        android:text="Understanding"
                        android:textColor="#666680"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tagPractice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/tab_inactive_bg"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="8dp"
                        android:text="Practice"
                        android:textColor="#666680"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tagSummary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/tab_inactive_bg"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="8dp"
                        android:text="Summary"
                        android:textColor="#666680"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tagSelf_test"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/tab_inactive_bg"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="8dp"
                    android:text="Self-test"
                    android:textColor="#666680"
                    android:textSize="12sp" />

                <!-- حقل النص -->
                <EditText
                    android:id="@+id/editImprove"
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:background="@drawable/input_field_bg"
                    android:gravity="top"
                    android:hint="How can the workflow be optimized tomorrow?"
                    android:inputType="textMultiLine"
                    android:paddingHorizontal="14dp"
                    android:paddingTop="12dp"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#333344"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_card_rounded"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_sparkle"
                        app:tint="#00E5FF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Effort &amp; Focus"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- How focused? -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="How focused were you during this session?"
                        android:textColor="#AAAACC"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/txtFocusValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:textColor="#00E5FF"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </RelativeLayout>

                <SeekBar
                    android:id="@+id/seekFocus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="16dp"
                    android:progressBackgroundTint="#1A1A2E"
                    android:progressTint="#00E5FF"
                    android:thumbTint="#00E5FF" />

                <!-- Effort level -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="Effort level"
                        android:textColor="#AAAACC"
                        android:textSize="12sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:id="@+id/txtEffortValue"
                        android:textColor="#00E5FF"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </RelativeLayout>

                <SeekBar
                    android:id="@+id/seekEffort"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="16dp"
                    android:progressBackgroundTint="#1A1A2E"
                    android:progressTint="#00E5FF"
                    android:thumbTint="#00E5FF" />

                <!-- Did you stay consistent? + Y/N -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="Did you stay consistent ?"
                        android:textColor="#AAAACC"
                        android:textSize="13sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/btnYes"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/tab_inactive_bg"
                            android:gravity="center"
                            android:text="Y"
                            android:textColor="#666680"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/btnNo"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/tab_inactive_bg"
                            android:gravity="center"
                            android:text="N"
                            android:textColor="#666680"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </RelativeLayout>
            </LinearLayout>

            <!-- ====== Emotional Reflection ====== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_card_rounded"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_person"
                        app:tint="#00E5FF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Emotional Reflection"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="How are you feeling right now?"
                    android:textColor="#AAAACC"
                    android:textSize="13sp" />

                <!-- Tags الصف الأول: EXHAUSTED / Motivated -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:orientation="horizontal">

                    <TextView
                         android:id="@+id/tagExhausted"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/tab_inactive_bg"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="8dp"
                        android:text="EXHAUSTED"
                        android:textColor="#666680"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tagMotivated"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/tab_inactive_bg"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="8dp"
                        android:text="Motivated"
                        android:textColor="#000000"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- Tags الصف الثاني: FRUSTRATED / Calm -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tagFrustrated"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/tab_inactive_bg"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="8dp"
                        android:text="FRUSTRATED"
                        android:textColor="#666680"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tagCalm"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/tab_inactive_bg"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="8dp"
                        android:text="Calm"
                        android:textColor="#666680"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- حقل نصي -->
                <EditText
                    android:id="@+id/editMotivation"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/input_field_bg"
                    android:hint="What helped you be motivated"
                    android:paddingHorizontal="14dp"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#333344"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- زر COMPLETE CHECK-IN -->
            <Button
                android:id="@+id/btnCompleteCheckin"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/btn_save"
                android:letterSpacing="0.1"
                android:text="COMPLETE CHECK-IN  🚀"
                android:textColor="#000000"
                android:textSize="15sp"
                android:textStyle="bold"
                app:backgroundTint="@null" />

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation -->
    <LinearLayout
        android:id="@+id/bottomNavBar"
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:layout_alignParentBottom="true"
        android:background="@drawable/bg_nav_bar"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="8dp">

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@drawable/ic_home" app:tint="#666680"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@drawable/ic_chart" app:tint="#00E5FF"/>
            <View android:layout_width="4dp" android:layout_height="4dp"
                android:layout_marginTop="4dp" android:background="#00E5FF"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@drawable/ic_person" app:tint="#666680"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@drawable/ic_modules" app:tint="#666680"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@drawable/ic_book" app:tint="#666680"/>
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>