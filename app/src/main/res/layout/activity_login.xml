<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="28dp"
        android:paddingTop="60dp"
        android:paddingBottom="40dp">

        <!-- ============ ICON ============ -->
        <FrameLayout
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/icon_bg">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_star"
                app:tint="@color/cyan_primary" />
        </FrameLayout>

        <!-- ============ TITLE ============ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="24dp"
            android:text="LOGIN"
            android:textColor="@color/white"
            android:textSize="32sp"
            android:letterSpacing="0.1"
            android:textStyle="bold" />

        <!-- ============ SUBTITLE ============ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:text="Enter your digital sanctuary"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <!-- ============ EMAIL LABEL ============ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:text="EMAIL OR USERNAME"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:letterSpacing="0.08"
            android:textStyle="bold" />

        <!-- ============ EMAIL FIELD ============ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/input_background"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="14dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_email"
                app:tint="@color/gray_hint" />

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:background="@null"
                android:hint="exemple@highschl.com"
                android:textColorHint="@color/gray_hint"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:inputType="textEmailAddress"
                android:singleLine="true" />
        </LinearLayout>

        <!-- ============ PASSWORD LABEL + FORGOT ============ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="PASSWORD"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:letterSpacing="0.08"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvForgot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FORGOT PASSWORD?"
                android:textColor="@color/cyan_primary"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- ============ PASSWORD FIELD ============ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/input_background"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="14dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_lock"
                app:tint="@color/gray_hint" />

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:background="@null"
                android:hint="••••••••••••"
                android:textColorHint="@color/gray_hint"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:inputType="textPassword"
                android:singleLine="true" />

            <ImageView
                android:id="@+id/ivTogglePassword"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_eye"
                app:tint="@color/gray_hint"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- ============ LOGIN BUTTON ============ -->
        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/btn_login"
            android:text="LOGIN"
            android:textColor="#000000"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:stateListAnimator="@null" />

        <!-- ============ OR DIVIDER ============ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="#2A2A2A" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:text="OR"
                android:textColor="@color/gray_hint"
                android:textSize="12sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="#2A2A2A" />
        </LinearLayout>

        <!-- ============ SOCIAL BUTTONS ============ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal">

            <!-- Google -->
            <LinearLayout
                android:id="@+id/btnGoogle"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:layout_marginEnd="10dp"
                android:background="@drawable/btn_social"
                android:orientation="horizontal"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_google" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="GOOGLE"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Apple -->
            <LinearLayout
                android:id="@+id/btnApple"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:background="@drawable/btn_social"
                android:orientation="horizontal"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_apple"
                    app:tint="@color/white" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="APPLE"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- ============ SIGN UP ============ -->
        <TextView
            android:id="@+id/tvSignUp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="40dp"
            android:textSize="13sp" />

    </LinearLayout>
</ScrollView>
